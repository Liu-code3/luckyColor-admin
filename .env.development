# title
VITE_TITLE = luckyColor-admin

# frontend request prefix
VITE_API_BASEURL = /api

# vite dev proxy target
VITE_API_PROXY_TARGET = http://127.0.0.1:3001

# default tenant header for local multi-tenant backend
