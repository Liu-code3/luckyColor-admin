# 开发环境后端代理地址
VITE_API_PROXY_TARGET=http://127.0.0.1:3001
# 开发环境默认关闭本地 Mock
VITE_API_MOCK_ENABLED=false
# 开发环境默认开启真实后端代理
VITE_API_PROXY_ENABLED=true
# 开发环境接口文档地址
VITE_API_DOC_URL=http://127.0.0.1:3001/docs
# 开发环境默认租户 ID
VITE_TENANT_ID=tenant_001

# 开发环境保留 debugger
VITE_BUILD_DROP_DEBUGGER=false
# 开发环境保留 console.log
VITE_BUILD_DROP_CONSOLE=false
# 开发环境开启 sourcemap，方便排查问题
VITE_BUILD_SOURCEMAP=true
# 开发环境部署基础路径
VITE_BUILD_PUBLIC_PATH=/
# 开发环境打包输出目录
VITE_BUILD_OUT_DIR=dist/dev

# 开发环境默认账号
VITE_APP_DEFAULT_USERNAME=admin
# 开发环境默认密码
VITE_APP_DEFAULT_PASSWORD=123456
# 开发环境验证码开关
VITE_LOGIN_CAPTCHA_ENABLED=true
# 开发环境租户模式开关
VITE_TENANT_ENABLED=true
