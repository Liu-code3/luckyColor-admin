# 应用基础标题
VITE_TITLE=luckyColor-admin
# 前端统一 API 前缀
VITE_API_BASEURL=/api
# 是否启用本地 Mock
VITE_API_MOCK_ENABLED=false
# 是否启用真实后端代理
VITE_API_PROXY_ENABLED=false
# 是否默认使用抽屉表单风格
VITE_SET_DRAWER=true
# 本地开发端口
VITE_PORT=9900

# 是否在构建时删除 debugger
VITE_BUILD_DROP_DEBUGGER=false
# 是否在构建时删除 console.log
VITE_BUILD_DROP_CONSOLE=false
# 是否生成 sourcemap
VITE_BUILD_SOURCEMAP=false
# 前端部署基础路径
VITE_BUILD_PUBLIC_PATH=/
# Vite 打包输出目录
VITE_BUILD_OUT_DIR=dist

# 登录页默认账号
VITE_APP_DEFAULT_USERNAME=admin
# 登录页默认密码
VITE_APP_DEFAULT_PASSWORD=123456
# 登录验证码总开关
VITE_LOGIN_CAPTCHA_ENABLED=true
# 租户模式总开关
VITE_TENANT_ENABLED=true
